# Runtime mode
APL_USE_MOCK=true
APL_RUNS_DIR=runs
APL_DEFAULT_MODEL=qwopus-q4km
APL_DEFAULT_TEMPERATURE=0.2
APL_HTTP_TIMEOUT_SECONDS=90

# OpenAI-compatible endpoint configuration
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# Optional per-agent model overrides
# APL_MODEL_RESEARCH_DIRECTOR=qwopus-q4km
# APL_MODEL_LITERATURE_REVIEW=qwopus-q4km
# APL_MODEL_DATA_SCOUT=qwopus-q4km
# APL_MODEL_POLICY_SCANNER=qwopus-q4km
# APL_MODEL_QUANTITATIVE_ANALYST=qwopus-q4km
# APL_MODEL_POLITICAL_ECONOMY=qwopus-q4km
# APL_MODEL_ECONOMIC_COMPLEXITY=qwopus-q4km
# APL_MODEL_SOURCE_QUALITY_AUDITOR=qwopus-q4km
# APL_MODEL_METHODOLOGY_REVIEWER=qwopus-q4km

# Optional data connector keys
BLS_API_KEY=
FRED_API_KEY=
CENSUS_API_KEY=
ONET_USERNAME=
ONET_PASSWORD=
SEMANTIC_SCHOLAR_API_KEY=
WEB_SEARCH_API_KEY=
